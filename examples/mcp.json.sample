{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_example"
      }
    },
    "browser-ops": {
      "type": "streamable-http",
      "url": "http://localhost:8787/mcp"
    }
  }
}
